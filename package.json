{
  "name": "hand-betting-game",
  "version": "1.0.0",
  "private": true,
  "description": "Mahjong-themed Hand Betting Game built with Nx, Angular, NestJS, and MongoDB.",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many --target=serve --projects=web,api --parallel",
    "start:web": "nx serve web",
    "start:api": "nx serve api",
    "build": "nx run-many --target=build --projects=web,api",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "test": "nx run-many --target=test --all",
    "test:engine": "nx test game-engine",
    "lint": "nx run-many --target=lint --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "seed:config": "ts-node --project tsconfig.base.json --transpile-only tools/seed-config.ts"
  },
  "dependencies": {
    "@angular/animations": "~17.3.0",
    "@angular/cdk": "~17.3.0",
    "@angular/common": "~17.3.0",
    "@angular/compiler": "~17.3.0",
    "@angular/core": "~17.3.0",
    "@angular/forms": "~17.3.0",
    "@angular/platform-browser": "~17.3.0",
    "@angular/platform-browser-dynamic": "~17.3.0",
    "@angular/router": "~17.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/platform-express": "^10.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mongoose": "^8.2.0",
    "primeicons": "^7.0.0",
    "primeng": "^17.10.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~17.3.0",
    "@angular-devkit/core": "~17.3.0",
    "@angular-devkit/schematics": "~17.3.0",
    "@angular/cli": "~17.3.0",
    "@angular/compiler-cli": "~17.3.0",
    "@angular/language-service": "~17.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@nx/angular": "18.3.0",
    "@nx/eslint": "18.3.0",
    "@nx/eslint-plugin": "18.3.0",
    "@nx/jest": "18.3.0",
    "@nx/js": "18.3.0",
    "@nx/nest": "18.3.0",
    "@nx/node": "18.3.0",
    "@nx/web": "18.3.0",
    "@nx/webpack": "18.3.0",
    "@nx/workspace": "18.3.0",
